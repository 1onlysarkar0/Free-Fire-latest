# ─────────────────────────────────────────────────────────────────────────────
# 1ONLYSARKAR - ENVIRONMENT CONFIGURATION (EXAMPLE)
# Copy this file to '.env' and fill in your actual credentials.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED CONFIGURATIONS ──────────────────────────────────────────────────

# PostgreSQL connection URL (e.g., Neon DB, Supabase, or Local DB)
# Note: Remove '&channel_binding=require' parameter if present to prevent Node.js connection issues.
DATABASE_URL="postgresql://username:password@host.tech/dbname?sslmode=require"

# Disables strict SSL rejection in development (set to "false" for Neon/pooled DBs)
DATABASE_SSL_REJECT_UNAUTHORIZED="false"

# Better Auth Secret: Cryptographic key for signing sessions & encrypting payment UTR payloads.
# Generate a secure key (e.g., using `openssl rand -hex 32` or similar, minimum 32 chars)
BETTER_AUTH_SECRET="your-32-character-minimum-secret-here"

# The public facing URL of the application. Required for auth redirects, emails, sitemaps, and robots.txt.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# IndexNow verification key. Host verification endpoint serving at /api/indexnow-key returns this.
INDEXNOW_KEY="your-indexnow-api-key-here"

# Secret Bearer Token for authenticating Cloudflare Email Worker Webhook (/api/webhooks/email-ingest)
EMAIL_WEBHOOK_SECRET="your-secure-webhook-bearer-token"


# ── OPTIONAL CONFIGURATIONS ──────────────────────────────────────────────────

# Custom port for the Next.js dev or prod server (defaults to 3000)
PORT=5000

# Google OAuth credentials (required for Google Sign-in integration)
GOOGLE_CLIENT_ID="your-google-client-id-here.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret-here"

# Comma-separated list of additional trusted CORS/OAuth origins if accessing from other domains
TRUSTED_ORIGINS=""

# Comma-separated list of additional dev server domains (e.g., custom tunnels or domains)
ALLOWED_DEV_ORIGINS=""

# Custom development domain (optional, if using a local development tunnel or proxy)
ONESARKAR_DEV_DOMAIN=""
